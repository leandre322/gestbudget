# .env.example — Template pour développeurs
# Remplacez les valeurs par les vôtres

# Neon PostgreSQL
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-bold-voice-aqo44zxw.c-8.us-east-1.aws.neon.tech/gestbudget?sslmode=require&channel_binding=require"
DATABASE_URL_UNPOOLED="postgresql://neondb_owner:YOUR_PASSWORD@ep-bold-voice-aqo44zxw-pooler.c-8.us-east-1.aws.neon.tech/gestbudget?sslmode=require&channel_binding=require"

# NextAuth (générer avec: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))")
