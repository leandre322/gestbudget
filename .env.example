# =============================================
# GestBudget — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# =============================================

# ── Neon PostgreSQL ──────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/gestbudget?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST-pooler/gestbudget?sslmode=require"

# ── NextAuth.js ──────────────────────────────
# Générer : openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-tres-long-et-aleatoire"
NEXTAUTH_URL="https://votre-app.vercel.app"

# ── Brevo SMTP ───────────────────────────────
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER="votre@email.com"
BREVO_SMTP_KEY="xsmtpsib-xxxxx"
BREVO_FROM_EMAIL="noreply@votredomaine.com"
BREVO_FROM_NAME="GestBudget"

# ── Application ──────────────────────────────
NEXT_PUBLIC_APP_URL="https://votre-app.vercel.app"
NEXT_PUBLIC_APP_NAME="GestBudget"
